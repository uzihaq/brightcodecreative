const HomePage = ({ navigate, scrollTarget, T, isMobile }) => {
  const [heroLoaded, setHeroLoaded] = useState(false);
  const [visibleSections, setVisibleSections] = useState(new Set());
  const [activeSection, setActiveSection] = useState(0);
  const sectionsRef = useRef([]);

  const scrollToSection = (index) => {
    sectionsRef.current[index]?.scrollIntoView({ behavior: "smooth" });
  };

  useEffect(() => {
    setHeroLoaded(true);
    if (scrollTarget !== null && scrollTarget !== undefined) {
      setTimeout(() => scrollToSection(scrollTarget), 100);
    }
  }, [scrollTarget]);

  useEffect(() => {
    const handleScroll = () => {
      const newVisible = new Set();
      sectionsRef.current.forEach((el, i) => {
        if (el) {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.85) newVisible.add(i);
        }
      });
      setVisibleSections(newVisible);

      // Active section for NavDots
      let current = 0;
      sectionsRef.current.forEach((el, i) => {
        if (el && el.getBoundingClientRect().top <= window.innerHeight * 0.4) current = i;
      });
      setActiveSection(current);
    };
    window.addEventListener("scroll", handleScroll);
    handleScroll();
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);

  return (
    <>
      {/* SIDE NAV DOTS */}
      {!isMobile && (
        <div style={{
          position: "fixed", right: 32, top: "50%", transform: "translateY(-50%)",
          display: "flex", flexDirection: "column", gap: 8, zIndex: 900,
        }}>
          {navLabels.map((label, i) => (
