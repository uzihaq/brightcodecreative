        );
      })()}

      <NavBar scrolled={scrolled} navigate={navigate} currentPage={page} T={T} isMobile={isMobile} lightMode={lightMode} onToggleLight={() => setLightMode(m => !m)} />

      {page === "home" && <HomePage navigate={navigate} scrollTarget={scrollTarget} T={T} isMobile={isMobile} />}
      {page === "work" && <WorkPage navigate={navigate} T={T} isMobile={isMobile} />}
      {page === "project" && <ProjectPage projectId={projectId} navigate={navigate} T={T} isMobile={isMobile} />}

      <Footer navigate={navigate} T={T} isMobile={isMobile} />
    </div>
  );
}
